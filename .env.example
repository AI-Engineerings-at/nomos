# NomOS Environment Configuration
# Copy to .env and replace ALL _REQUIRED values before running docker compose up.
# WARNING: docker compose will REFUSE to start with placeholder values.

# ─── REQUIRED SECRETS (no defaults — must be set) ──────
NOMOS_JWT_SECRET=CHANGE_ME_REQUIRED_min_32_chars
NOMOS_PLUGIN_API_KEY=CHANGE_ME_REQUIRED_plugin_key
NOMOS_GATEWAY_TOKEN=CHANGE_ME_REQUIRED_gateway_token
NOMOS_DB_PASSWORD=CHANGE_ME_REQUIRED_db_password

# ─── Vault (optional — AppRole credentials from vault/init.sh) ──
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ─── Runtime ───────────────────────────────────────────
NOMOS_DEV_MODE=false

# ─── Ports (optional — defaults shown) ─────────────────
NOMOS_GATEWAY_PORT=3050
NOMOS_API_PORT=8060
NOMOS_CONSOLE_PORT=3040
VAULT_PORT=8200

# ─── LLM Provider — choose ONE (NomOS is provider-agnostic) ──
# NVIDIA (recommended, Free Tier available): https://catalog.ngc.nvidia.com/
NVIDIA_API_KEY=nvapi-...
# Or Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# Or OpenAI:
# OPENAI_API_KEY=sk-...
