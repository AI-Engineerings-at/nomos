# NomOS Environment Configuration
# Copy to .env and replace ALL _REQUIRED values before running docker compose up.
# WARNING: docker compose will REFUSE to start with placeholder values.

# ─── REQUIRED SECRETS (no defaults — must be set) ──────────────────
# These are hardened secrets. Set them to strong random values before deployment.

# 32+ character JWT secret for session management
NOMOS_JWT_SECRET=CHANGE_ME_REQUIRED_min_32_chars

# Plugin authentication key (for OpenClaw gateway communication)
NOMOS_PLUGIN_API_KEY=CHANGE_ME_REQUIRED_plugin_key

# Gateway authentication token (for bidirectional gateway<->API auth)
NOMOS_GATEWAY_TOKEN=CHANGE_ME_REQUIRED_gateway_token

# PostgreSQL password (used by postgres, nomos-api, nomos-worker)
NOMOS_DB_PASSWORD=CHANGE_ME_REQUIRED_db_password

# ─── LLM Provider Keys (choose at least ONE for chat functionality) ──
# NomOS is provider-agnostic. At least one API key required for agent chat.

# NVIDIA (recommended, free tier available): https://build.nvidia.com
NVIDIA_API_KEY=

# Anthropic Claude API: https://console.anthropic.com
# ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com
# OPENAI_API_KEY=

# ─── HashiCorp Vault (Secret Management) ──────────────────────────
# AppRole credentials auto-populated by vault/init.sh on first run.
# Only set manually if running Vault elsewhere.

VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ─── Runtime Configuration ────────────────────────────────────────

# Development mode (enables logging, debug endpoints, disables some security checks)
NOMOS_DEV_MODE=false

# Cookie security flag (set to false for http://localhost testing only)
NOMOS_COOKIE_SECURE=true

# ─── TLS / Reverse Proxy ──────────────────────────────────────────

# Domain for TLS certificate generation (caddy service)
# For production: use your actual domain (e.g., nomos.example.com)
# For localhost: keep as-is
NOMOS_DOMAIN=localhost

# ─── Service Ports (optional — defaults shown) ─────────────────────
# Uncomment and change if you need non-default ports

# OpenClaw Gateway (headless plugin framework)
# NOMOS_GATEWAY_PORT=3050

# NomOS API Control Plane (FastAPI backend)
# NOMOS_API_PORT=8060

# NomOS Console (Next.js frontend)
# NOMOS_CONSOLE_PORT=3040

# HashiCorp Vault (secret management)
# VAULT_PORT=8200

# Valkey (Redis-compatible cache, defaults to 6379 internal, 6380 exposed)
# NOMOS_VALKEY_PORT=6380

# ─── Speech Services (optional, enable via docker compose --profile speech) ──

# Piper TTS (text-to-speech, German DE-Thorsten voice)
# NOMOS_PIPER_PORT=10200

# Faster Whisper STT (speech-to-text, base model, German language)
# NOMOS_WHISPER_PORT=10300

# ─── HTTP/HTTPS Ports (caddy reverse proxy, optional) ──────────────
# NOMOS_HTTP_PORT=80
# NOMOS_HTTPS_PORT=443
