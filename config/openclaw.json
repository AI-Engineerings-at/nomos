{
  "tools": {
    "profile": "coding",
    "fs": { "workspaceOnly": true }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "models": {
    "providers": {
      "nvidia": {
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "api": "openai-completions",
        "models": [{"id": "meta/llama-3.3-70b-instruct", "name": "Llama 3.3 70B"}]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "nvidia/meta/llama-3.3-70b-instruct"
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "discovery": {
    "mdns": { "mode": "off" }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "enabled": false
    },
    "http": {
      "endpoints": {
        "chatCompletions": { "enabled": true }
      }
    },
    "auth": {
      "mode": "token",
      "token": "nomos-dev-token"
    }
  }
}
